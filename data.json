name: Sync Google Sheets to JSON
on:
  schedule:
    - cron: '0 * * * *' # Runs every hour
  workflow_dispatch: # Allows manual trigger

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Fetch Latest Data
        run: |
          # Replace with your Google Script URL that returns the full JSON
          curl -L "https://script.google.com/macros/s/AKfycbwj99w9IceN2W1aF3S-jN6yFypMBszvb1xv7FTUuYrW-GbYjC4ediZHrscrloeprwCSSw/exec" -o data.json
      - name: Commit and Push
        run: |
          git config --global user.name 'Sync Bot'
          git config --global user.email 'bot@github.com'
          git add data.json
          git commit -m "Update Local DB 🇮🇶" || exit 0
          git push
